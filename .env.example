# RunCommerce Site — Environment Variables
# Copy this file to .env and fill in values. Never commit .env to git.

# Site URL (used for canonical links, OG tags, etc.)
VITE_SITE_URL=https://runcommerce.ai

# Loops.so API key for email capture on Coming Soon page
VITE_LOOPS_API_KEY=

# Contact form endpoint (if/when a backend is added)
# VITE_CONTACT_FORM_URL=

# Analytics (optional)
# VITE_GA_MEASUREMENT_ID=
